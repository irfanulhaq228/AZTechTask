# Runs in parallel with `deps` on first build — bundles Prisma CLI for `migrate` (no `npx` download at container start).
FROM node:22-alpine AS prisma-cli
WORKDIR /cli
RUN printf '%s\n' '{"private":true,"dependencies":{"prisma":"7.7.0","dotenv":"17.4.2"}}' > package.json \
  && npm install --omit=dev \
  && npm cache clean --force

FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
# Install all deps for `next build` + Prisma generate; devDependencies stay in this stage only.
RUN npm ci

FROM node:22-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
# Prisma v7 reads datasource URLs from `prisma.config.ts` using `env("DATABASE_URL")`.
# During `docker build`, Compose `.env` is not automatically injected, and `.env` is dockerignored,
# so we provide a syntactically-valid placeholder for `prisma generate` / `next build`.
# Runtime still uses the real `DATABASE_URL` from `docker compose` env_file / container env.
ENV DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/products?schema=public"
RUN npx prisma generate && npm run build

FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
# Do not copy the full `node_modules` from the deps stage: Next `output: "standalone"` already
# bundles traced runtime deps (including Prisma client). Copying both duplicates ~1GB+ of packages.
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/prisma ./prisma
COPY --from=builder /app/prisma.config.ts ./prisma.config.ts
COPY --from=builder /app/public ./public
# Local Prisma CLI for the `migrate` service (see docker-compose `command`).
COPY --from=prisma-cli /cli ./prisma-migrate-deps
# `prisma.config.ts` imports `dotenv/config`; keep resolvable from `/app` when the CLI loads the config.
COPY --from=deps /app/node_modules/dotenv ./node_modules/dotenv
EXPOSE 3000
# Schema changes run in the `migrate` service; web only serves the app.
CMD ["node", "server.js"]
